// White One ERP v2 — Prisma schema
// Фокус: продуктовая разработка. WB-метрики вне системы.
// Ядра: ProductModel (фасон) + ProductVariant (цветовой вариант) + Order.
// Дополнительно: Sample (образец), Idea (идея), SizeGrid (размерные сетки).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================================
// ENUMS
// ======================================================

enum Role {
  OWNER
  DIRECTOR
  PRODUCT_MANAGER
  ASSISTANT
  CONTENT_MANAGER
  LOGISTICS
  CUSTOMS
  WB_MANAGER
  INTERN
}

enum DevelopmentType {
  OWN
  REPEAT
}

enum Brand {
  WHITE_ONE
  SERDCEBIENIE
}

// Упрощённая машина статусов (5 вместо 8).
// Корректировки и размерная сетка — подэтапы SAMPLE через чекбоксы.
enum ProductModelStatus {
  IDEA
  PATTERNS
  SAMPLE
  APPROVED
  IN_PRODUCTION
}

enum ProductVariantStatus {
  DRAFT
  READY_TO_ORDER
  DISCONTINUED
}

enum OrderType {
  SEASONAL
  RESTOCK
  TEST
}

enum OrderStatus {
  PREPARATION
  FABRIC_ORDERED
  SEWING
  QC
  READY_SHIP
  IN_TRANSIT
  WAREHOUSE_MSK
  PACKING
  SHIPPED_WB
  ON_SALE
}

enum DeliveryMethod {
  DOMESTIC_RU
  CARGO_KG
  CARGO_CN
  TK_CN
}

enum NotificationChannel {
  TELEGRAM
  IN_APP
  EMAIL
}

enum NotificationType {
  DELAY
  INCOMING_DELIVERY
  PAYMENT_DUE
  PLAN_GAP
  STATUS_CHANGED
  ISSUE
  SAMPLE_READY
  QC_REQUIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  IMPORT
  EXPORT
}

enum Currency {
  RUB
  CNY
}

enum PaymentType {
  ORDER      // Платёж по заказу на производство (фабрика)
  PACKAGING  // Платёж поставщику упаковки
}

enum PaymentStatus {
  PENDING
  PAID
}

enum PackagingItemStatus {
  IDEA          // Идея, ещё ничего не заказывали
  DESIGN        // Разработка макета/дизайна
  SAMPLE        // Получен/ждём образец
  APPROVED      // Образец утверждён
  ACTIVE        // В массовом производстве/использовании
  ARCHIVED      // Снято с использования
}

// Статус поставки (группы партий, едущих одним транспортом на склад МСК).
enum ShipmentStatus {
  DRAFT       // Черновик — собираем партии, ещё не выехала
  IN_TRANSIT  // В пути (проставлена дата выезда)
  ARRIVED     // Приехала на склад, идёт приёмка
  RECEIVED    // Приёмка завершена по всем партиям
}

// Статус образца фасона: заказан у фабрики → едет → получен → вердикт.
// «На доработку» = итерация: правки уходят фабрике, следующий образец — новой записью.
enum SampleStatus {
  ORDERED     // Заказан у фабрики
  IN_TRANSIT  // Едет к нам
  RECEIVED    // Получен, ждёт вердикта
  APPROVED    // Ок — образец утверждён
  REWORK      // На доработку
}

enum PackagingType {
  LABEL        // Бирки (навесные, обшивные)
  SIZE_LABEL   // Размерники
  POLYBAG      // Полибэг / пакет
  MESH         // Сетка
  COVER        // Чехол
  BAG          // Сумка
  BOX          // Коробка
  CARE_LABEL   // Ярлык ухода / состав
  OTHER
}

// ======================================================
// USER
// ======================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(INTERN)
  isActive     Boolean  @default(true)

  telegramChatId   BigInt?   @unique
  telegramLinkCode String?
  telegramLinkedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedModels       ProductModel[]       @relation("ModelOwner")
  ownedOrders       Order[]              @relation("OrderOwner")
  modelLogs         ProductModelStatusLog[] @relation("ModelStatusActor")
  variantLogs       ProductVariantStatusLog[] @relation("VariantStatusActor")
  orderLogs         OrderStatusLog[]     @relation("OrderStatusActor")
  auditLogs         AuditLog[]
  notifications     Notification[]
  createdPayments   Payment[]            @relation("PaymentCreator")
  createdSamples    Sample[]             @relation("SampleCreator")
  paidPayments      Payment[]            @relation("PaymentPayer")
  createdPayouts    FactoryPayout[]      @relation("PayoutCreator")
  ownedPackagingItems PackagingItem[]    @relation("PackagingOwner")
  ownedBrandPlans   BrandPlan[]          @relation("BrandPlanOwner")
  packagingStatusLogs PackagingItemStatusLog[] @relation("PackagingStatusActor")
  ownedPackagingOrders PackagingOrder[]  @relation("PackagingOrderOwner")
  ownedPlans          MonthlyPlan[]      @relation("PlanOwner")
  createdShipments    Shipment[]         @relation("ShipmentCreator")
  createdChinaQcs     ChinaQc[]          @relation("ChinaQcCreator")

  @@index([role])
  @@index([isActive])
}

// ======================================================
// FACTORY
// ======================================================

// Тип фабрики (П6 UX-аудита): швейная или поставщик упаковки.
// В формах фасона/заказа показываются только швейные —
// упаковщики больше не всплывают в списке фабрик пошива.
enum FactoryKind {
  SEWING
  PACKAGING
}

model Factory {
  id               String   @id @default(cuid())
  name             String   @unique
  kind             FactoryKind @default(SEWING)
  country          String
  city             String?
  contactName      String?
  contactInfo      String?
  capacityPerMonth Int?
  notes            String?
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferredForModels ProductModel[]   @relation("ModelPreferredFactory")
  orders             Order[]
  payments           Payment[]
  packagingOrders    PackagingOrder[] @relation("PackagingOrderFactory")
  payouts            FactoryPayout[]
  samples            Sample[]

  @@index([isActive])
}

// ======================================================
// SAMPLE (образец фасона) — вторая, лёгкая версия.
// Первую убили 26.04.2026 как переусложнённую; 03.07.2026 Алёна попросила
// вернуть простой учёт: заказан → едет → получен → вердикт, фото и даты.
// История хранится записями (итерация доработки = новый образец), не логом.
// ======================================================
model Sample {
  id             String       @id @default(cuid())
  productModelId String
  productModel   ProductModel @relation(fields: [productModelId], references: [id], onDelete: Cascade)
  factoryId      String?
  factory        Factory?     @relation(fields: [factoryId], references: [id], onDelete: SetNull)

  label          String?      // «44 размер, ткань лён», «2-я итерация»
  status         SampleStatus @default(ORDERED)

  orderedDate    DateTime?    // когда заказали у фабрики
  receivedDate   DateTime?    // когда получили
  verdictDate    DateTime?    // когда дали вердикт (ок / на доработку)
  verdictNote    String?      // текст вердикта: что не так / что ок

  photoUrls      String[]

  createdById    String?
  createdBy      User?        @relation("SampleCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([productModelId])
  @@index([status])
  @@index([deletedAt])
}

// ======================================================
// SIZE GRID (справочник размерных сеток)
// ======================================================

model SizeGrid {
  id        String   @id @default(cuid())
  name      String   @unique                 // "40-60 пальто", "42-52 стандарт", "XS-XXL"
  sizes     String[]                         // ["40", "42", "44", "46", "48", "50"]
  notes     String?

  createdAt DateTime @default(now())

  models ProductModel[]
}

// ======================================================
// PRODUCT MODEL (фасон)
// ======================================================

model ProductModel {
  id           String          @id @default(cuid())
  name         String                                           // "Пальто Классика Двубортное Миди"
  brand        Brand  @default(WHITE_ONE)
  category     String                                           // Пальто / Брюки / Лето / Новые товары
  subcategory  String?                                          // Пальто Классика Миди / Палаццо оверсайз / ...

  // Базовая часть артикула (= vendorCode на WB), общая для всех цветов фасона.
  // Алфавит выбирает страна (Честный знак печатается на производстве):
  //   Китай/Кыргызстан → латиница: dress_kimono ; Россия → кириллица: П_040.
  // Цвет дописывается на варианте: ProductVariant.sku = artikulBase + "_" + цвет.
  artikulBase  String?

  // Размерная сетка
  sizeGridId   String?
  sizeGrid     SizeGrid?       @relation(fields: [sizeGridId], references: [id])

  // Ткань — простые опциональные поля (не отдельная сущность)
  // Если true — закупка «под ключ», ткань отдельно не учитывается, fabric-поля игнорируются
  turnkeyPurchase      Boolean  @default(false)

  // Таргет себестоимости — предварительная оценка на момент разработки фасона.
  // Точная себестоимость фиксируется в заказе, после согласования с фабрикой.
  targetCostRub        Decimal? @db.Decimal(12, 2)
  targetCostCny        Decimal? @db.Decimal(12, 2)
  targetCostNote       String?

  fabricName           String?
  fabricComposition    String?                                   // "70% шерсть, 30% полиэстер"
  fabricConsumption    Decimal? @db.Decimal(6, 2)               // метров на единицу
  fabricPricePerMeter  Decimal? @db.Decimal(12, 2)
  fabricCurrency       Currency?                                // RUB | CNY

  // Экономика — одна для всех цветов фасона (перенесли с варианта)
  // Фабрика даёт одну закупочную цену на модель, WB-цена/комиссия/ДРР обычно тоже общие.
  purchasePriceCny     Decimal? @db.Decimal(12, 2)
  purchasePriceRub     Decimal? @db.Decimal(12, 2)
  cnyRubRate           Decimal? @db.Decimal(10, 4)
  packagingCost        Decimal  @default(0) @db.Decimal(12, 2)
  wbLogisticsCost      Decimal  @default(0) @db.Decimal(12, 2)
  wbPrice              Decimal? @db.Decimal(12, 2)
  customerPrice        Decimal? @db.Decimal(12, 2)
  wbCommissionPct      Decimal  @default(0) @db.Decimal(5, 2)
  drrPct               Decimal  @default(0) @db.Decimal(5, 2)
  plannedRedemptionPct Decimal? @db.Decimal(5, 2)

  // Экономика — расчётные поля
  fullCost             Decimal? @db.Decimal(12, 2)
  marginBeforeDrr      Decimal? @db.Decimal(12, 2)
  marginAfterDrrPct    Decimal? @db.Decimal(6, 2)
  roi                  Decimal? @db.Decimal(6, 2)
  markupPct            Decimal? @db.Decimal(6, 2)

  // Производство
  countryOfOrigin      String                                   // "Россия" / "Китай" / "Кыргызстан"

  // Маркировка «Честный знак» — атрибуты для Национального каталога.
  // Код ТНВЭД ЕАЭС (10 знаков) общий для всех цветов фасона; состав ткани
  // берётся из fabricComposition. Аудит нашёл ТНВЭД «полем-фантомом»
  // (упоминался в комментах, но в БД/формах его не было) — заводим по-настоящему.
  tnvedCode            String?

  preferredFactoryId   String?
  preferredFactory     Factory? @relation("ModelPreferredFactory", fields: [preferredFactoryId], references: [id])

  developmentType DevelopmentType @default(OWN)
  isRepeat         Boolean         @default(false)
  previousVersionId String?                                     // Ссылка на предыдущую версию (self-ref)
  previousVersion   ProductModel?  @relation("ModelVersioning", fields: [previousVersionId], references: [id])
  nextVersions      ProductModel[] @relation("ModelVersioning")

  // Документация — одна общая ссылка на папку с материалами (лекала, тех-пакет, фото).
  patternsUrl       String?

  // Фото модели (общие, без цвета).
  photoUrls         String[]

  // Технический флэт-контур (SVG, перекрашиваемый: заливка fill="currentColor").
  // Генерится из photoUrls через NB Pro + potrace. Доска «Раскладка по цветам».
  flatSketchSvg     String?

  // Цвета (hex), выложенные для этого фасона на доске коллекции. Пусто = не на доске.
  boardColors       String[]

  // Порядок ряда на доске коллекции (drag-сортировка). null = по категории/имени.
  collectionOrder   Int?

  // Координаты и размер карточки на бесконечной доске (/models/board, Miro-аналог).
  // Общие для всех — кабинет один на команду. null = ещё не размещена (раскладка сеткой).
  canvasX           Float?
  canvasY           Float?
  canvasW           Float?
  canvasH           Float?
  canvasZ           Int?

  // Пропорция размеров по умолчанию (% на размер). Например, { "42": 10, "44": 25, ... }.
  // Используется как шаблон при создании заказа. На варианте можно переопределить, если цвет продаётся иначе.
  defaultSizeProportion Json?

  // Подэтапы SAMPLE (флаги, не статусы)
  correctionsNeeded Boolean @default(false)
  sizeChartReady    Boolean @default(false)

  status     ProductModelStatus @default(IDEA)
  // activated = фасон официально запущен в работу.
  // Создаётся как false если фасон возник из черновика-образца (Sample-first flow).
  // Активируется кнопкой «Запустить фасон» на утверждённом образце.
  // Существующие фасоны помечаются true миграцией (default true для новых записей).
  activated  Boolean @default(true)
  ownerId    String
  owner      User           @relation("ModelOwner", fields: [ownerId], references: [id])

  // Даты этапов
  patternsDate DateTime?
  sampleDate   DateTime?
  approvedDate DateTime?
  productionStartDate DateTime?
  plannedLaunchMonth Int?                                       // YYYYMM

  notes     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  variants    ProductVariant[]
  orders      Order[]                                         @relation("ModelOrders")
  statusLogs  ProductModelStatusLog[]
  packagingItems   ModelPackaging[]
  samples     Sample[]
  regulatoryDocs RegulatoryDoc[] @relation("ModelRegulatoryDocs")

  // Фасон разрабатывается в рамках плана-направления («Планирование»)
  brandPlanId String?
  brandPlan   BrandPlan? @relation(fields: [brandPlanId], references: [id])

  @@index([status])
  @@index([ownerId])
  @@index([category])
  @@index([deletedAt])
  @@index([plannedLaunchMonth])
  @@index([artikulBase])
}

// Комплект упаковки на уровне фасона — шаблон, автоматически применяется
// при создании заказа (копируется в OrderPackaging).
model ModelPackaging {
  id               String        @id @default(cuid())
  productModelId   String
  productModel     ProductModel  @relation(fields: [productModelId], references: [id], onDelete: Cascade)
  packagingItemId  String
  packagingItem    PackagingItem @relation(fields: [packagingItemId], references: [id])

  quantityPerUnit  Decimal @default(1) @db.Decimal(6, 2)

  createdAt DateTime @default(now())

  @@unique([productModelId, packagingItemId])
  @@index([productModelId])
  @@index([packagingItemId])
}

// ======================================================
// PRODUCT VARIANT (цветовой вариант)
// ======================================================

model ProductVariant {
  id             String  @id @default(cuid())
  productModelId String
  productModel   ProductModel @relation(fields: [productModelId], references: [id])

  sku            String  @unique                // П_038_шоколад_безэполет
  colorName      String                          // шоколад
  fabricColorCode String?                        // Артикул цвета у поставщика ткани (для повторного заказа)

  // Фото — КРИТИЧНО. Минимум 1 фото валидируется на уровне формы.
  photoUrls      String[]

  // Размерная пропорция по умолчанию { "42": 10, "44": 25, ... } (%)
  defaultSizeProportion Json?

  // % выкупа по факту — ручной ввод из WB, зависит от цвета (один продаётся лучше другого).
  // Вся остальная экономика (закупка, WB-цена, комиссия, ДРР, планируемый выкуп) — на уровне фасона.
  factRedemptionPct    Decimal? @db.Decimal(5, 2)

  // Габариты (могут переопределяться на уровне варианта)
  lengthCm Decimal? @db.Decimal(6, 1)
  widthCm  Decimal? @db.Decimal(6, 1)
  heightCm Decimal? @db.Decimal(6, 1)
  weightG  Int?
  liters   Decimal? @db.Decimal(6, 2)

  packagingType String?

  status ProductVariantStatus @default(READY_TO_ORDER)

  notes    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orderLines OrderLine[] @relation("VariantOrderLines")
  statusLogs ProductVariantStatusLog[]
  gtins      VariantGtin[]

  @@index([productModelId])
  @@index([sku])
  @@index([status])
  @@index([deletedAt])
}

// ОТК Китай — выездная проверка качества на фабрике (Алёна 16.07: «заводим
// ОТК, у него есть стоимость и заказ; работает как доставка — прикрепляем,
// стоимость ложится в себестоимость»). Курс фиксируется на дату ОТК.
model ChinaQc {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("CNY")            // CNY | USD | RUB
  rubRate     Decimal?  @db.Decimal(12, 4)          // ₽ за единицу валюты на дату (RUB = 1)
  comment     String?
  createdById String
  createdBy   User      @relation("ChinaQcCreator", fields: [createdById], references: [id])
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orderId])
  @@index([deletedAt])
}

// GTIN Честного знака на цветомодель×размер. Присваивается ЧЗ после загрузки
// IMPORT_K3; принимаем обратно выгрузкой (тот же файл с заполненным «Кодом
// товара») на вкладке «Честный знак». Нужен для IMPORT_RD (декларации).
model VariantGtin {
  id        String   @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  size      String
  gtin      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([variantId, size])
  @@index([variantId])
}

// Разрешительный документ (декларация/сертификат соответствия) для ЧЗ.
// Одна декларация покрывает несколько фасонов; из неё собирается IMPORT_RD.
model RegulatoryDoc {
  id        String   @id @default(cuid())
  kind      String   @default("DECLARATION")   // DECLARATION (id ЧЗ 23557) | CERTIFICATE (23561)
  number    String                              // «ЕАЭС N RU Д-RU.РА03.В.01124/25»
  date      DateTime @db.Date                   // дата регистрации
  comment   String?
  models    ProductModel[] @relation("ModelRegulatoryDocs")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ======================================================
// ORDER (заказы на производство)
// ======================================================

model Order {
  id               String          @id @default(cuid())
  orderNumber      String          @unique

  // Фасон (общий для всех позиций). Позиции = разные цвета этого фасона.
  productModelId   String
  productModel     ProductModel    @relation("ModelOrders", fields: [productModelId], references: [id])

  // Позиции заказа (цвета + количества + размерные матрицы + снимки экономики на цвет)
  lines            OrderLine[]

  orderType   OrderType
  season      String?
  launchMonth Int

  // Производство
  factoryId      String?
  factory        Factory? @relation(fields: [factoryId], references: [id])
  ownerId        String
  owner          User     @relation("OrderOwner", fields: [ownerId], references: [id])
  deliveryMethod DeliveryMethod?

  status OrderStatus @default(PREPARATION)

  // Даты этапов
  decisionDate         DateTime?
  handedToFactoryDate  DateTime?
  sewingStartDate      DateTime?
  readyAtFactoryDate   DateTime?
  qcDate               DateTime?
  shipmentDate         DateTime?
  arrivalPlannedDate   DateTime?
  arrivalActualDate    DateTime?
  packingDoneDate      DateTime?
  wbShipmentDate       DateTime?
  saleStartDate        DateTime?

  // Оплаты
  paymentTerms       String?
  prepaymentAmount   Decimal?  @db.Decimal(14, 2)
  prepaymentDate     DateTime?
  prepaymentPaid     Boolean   @default(false)
  finalPaymentAmount Decimal?  @db.Decimal(14, 2)
  finalPaymentDate   DateTime?
  finalPaymentPaid   Boolean   @default(false)

  // Упаковка
  packagingType    String?
  packagingOrdered Boolean @default(false)

  // Флаги
  isDelayed   Boolean @default(false)
  hasIssue    Boolean @default(false)
  wbCardReady Boolean @default(false)

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  statusLogs OrderStatusLog[]
  packagingItems OrderPackaging[]
  payments Payment[]
  batches  OrderBatch[]
  chinaQcs ChinaQc[]

  @@index([orderNumber])
  @@index([productModelId])
  @@index([status])
  @@index([launchMonth])
  @@index([ownerId])
  @@index([factoryId])
  @@index([deletedAt])
  @@index([isDelayed])
}

// Позиция заказа — цвет + количество + размерная матрица + снимки экономики.
// В одном заказе несколько позиций = несколько цветов одного фасона.
model OrderLine {
  id               String          @id @default(cuid())
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant  @relation("VariantOrderLines", fields: [productVariantId], references: [id])

  quantity Int                            // План — сколько заказали с фабрики
  quantityActual Int?                     // Факт — сколько реально получили после ОТК
                                          // (фабрика накроила больше/меньше, или брак вылез).
                                          // Заполняется на этапе QC/READY_SHIP. До этого null.

  // Размерная матрица — план и факт
  sizeDistribution       Json?   // { "42": 50, "44": 120, ... }
  sizeDistributionActual Json?

  // Снимки финансов (копируются из productModel в момент создания заказа)
  snapshotFullCost         Decimal? @db.Decimal(12, 2)
  snapshotWbPrice          Decimal? @db.Decimal(12, 2)
  snapshotCustomerPrice    Decimal? @db.Decimal(12, 2)
  snapshotWbCommissionPct  Decimal? @db.Decimal(5, 2)
  snapshotDrrPct           Decimal? @db.Decimal(5, 2)
  snapshotRedemptionPct    Decimal? @db.Decimal(5, 2)

  // Расчётные (по позиции)
  batchCost      Decimal? @db.Decimal(14, 2)
  plannedRevenue Decimal? @db.Decimal(14, 2)
  plannedMargin  Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productVariantId])
}

// ======================================================
// ПАРТИИ / ПОСТАВКИ / ПРИЁМКА
// ======================================================
// Боль Алёны: «фабрика сшила чуть по-другому — приёмка поштучно; заказ сдаётся
// в несколько партий; несколько заказов уезжает в одной поставке».
//
// OrderBatch — партия заказа (кусок заказа, едущий отдельно). У простого заказа
// партия одна и создаётся ЛЕНИВО (при первом добавлении в поставку) со всеми
// позициями из линий заказа — обычному случаю никакой лишней возни.
// Shipment — поставка: группа партий (возможно разных заказов), едущая на склад.

model OrderBatch {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  index      Int                                   // Номер партии в заказе 1..N (для подписи «партия 1/2»)

  // Поставка, в которой едет партия (null — партия ещё не назначена в поставку).
  shipmentId String?
  shipment   Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  // Дата завершения приёмки партии. null — приёмка не завершена.
  receivedAt DateTime?
  note       String?

  // Вес партии в карго, кг — ручная поправка. null = считаем из штук × вес
  // штуки цветомодели (ProductVariant.weightG). Партия бывает тяжелее образца.
  weightKgOverride Decimal? @db.Decimal(10, 1)

  items      OrderBatchItem[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([orderId, index])
  @@index([orderId])
  @@index([shipmentId])
  @@index([receivedAt])
}

// Позиция партии — по образцу OrderLine (цвет + размер + кол-во), но с фактом
// приёмки поштучно. variantId опционален: строку можно добавить руками при
// приёмке, если фабрика сшила размер/цвет, которого не было в заказе.
model OrderBatchItem {
  id          String  @id @default(cuid())
  batchId     String
  batch       OrderBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  variantId   String?                              // Ссылка на ProductVariant (если позиция из заказа)
  colorName   String                               // Цвет (денормализовано, как в OrderLine.productVariant.colorName)
  size        String                               // Размер («42», «44», ...)

  plannedQty  Int                                  // План — сколько этой позиции едет в партии
  factQty     Int?                                 // Факт — сколько реально приняли (null — не принимали)
  defectQty   Int?                                 // Брак — сколько с браком
  note        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([batchId])
  @@index([variantId])
}

model Shipment {
  id          String         @id @default(cuid())
  number      String         @unique              // SHP-YYYY-NNNN (генерация как orderNumber)
  status      ShipmentStatus @default(DRAFT)

  departDate  DateTime?                            // Дата выезда (перевод в IN_TRANSIT)
  arriveDate  DateTime?                            // Дата прибытия на склад (перевод в ARRIVED) — ПЛАН
  carrier     String?                              // Перевозчик / способ
  comment     String?

  // ─── Карго-накладная (перенос листа «КАРГО» из Excel-матрицы, 04.07.2026) ───
  // Одна поставка = одна накладная карго (номер вида M0514-4759-47).
  cargoNumber       String?   @unique              // номер накладной карго
  placesCount       Int?                           // количество мест
  weightKg          Decimal?  @db.Decimal(10, 1)   // вес брутто, кг
  amountUsdt        Decimal?  @db.Decimal(12, 2)   // сумма к оплате карго, USDT (= фрахт+страховка+упаковка)
  cargoPaidAt       DateTime?                      // null = карго не оплачено
  arrivalActualDate DateTime?                      // ФАКТ прибытия в Москву

  // ─── Деньги накладной раздельно (как в китайской накладной) и курс (Алёна 16.07) ───
  freightUsd        Decimal?  @db.Decimal(12, 2)   // 运费 стоимость транспортировки
  insuranceUsd      Decimal?  @db.Decimal(12, 2)   // 保费 страховка
  packingFeeUsd     Decimal?  @db.Decimal(12, 2)   // 打包费 упаковка груза
  // Курс USD→RUB, зафиксированный в момент оплаты карго (cargoPaidAt).
  // Пока не оплачено — раскидка считается по курсу ЦБ на сегодня (CurrencyRate).
  usdRubRate        Decimal?  @db.Decimal(10, 4)
  // Файлы накладной (фото/скрины) — drag-n-drop или камера с телефона.
  waybillPhotoUrls  String[]  @default([])

  createdById String
  createdBy   User           @relation("ShipmentCreator", fields: [createdById], references: [id])

  // Мягкое удаление (только OWNER/DIRECTOR) — «никогда не удаляем физически».
  deletedAt   DateTime?

  batches         OrderBatch[]
  // Заказы упаковки едут тем же карго, что и одежда (лист КАРГО: сумки, бирки, плечики).
  packagingOrders PackagingOrder[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@index([deletedAt])
  @@index([number])
}

// История официальных курсов ЦБ РФ (USD, CNY) — для расчёта стоимости карго
// и тестовой модели себестоимости. Подтягивается лениво при обращении
// (fetch XML_daily ЦБ) и кэшируется здесь. USDT считаем как USD (Алёна 16.07).
model CurrencyRate {
  id        String   @id @default(cuid())
  date      DateTime @db.Date                     // дата курса (день)
  code      String                                // "USD" | "CNY"
  rate      Decimal  @db.Decimal(12, 4)           // ₽ за 1 единицу валюты
  createdAt DateTime @default(now())

  @@unique([date, code])
  @@index([code, date])
}

// ======================================================
// STATUS LOGS
// ======================================================

model ProductModelStatusLog {
  id             String              @id @default(cuid())
  productModelId String
  productModel   ProductModel        @relation(fields: [productModelId], references: [id], onDelete: Cascade)
  fromStatus     ProductModelStatus?
  toStatus       ProductModelStatus
  changedById    String
  changedBy      User                @relation("ModelStatusActor", fields: [changedById], references: [id])
  comment        String?
  changedAt      DateTime            @default(now())

  @@index([productModelId, changedAt])
}

model ProductVariantStatusLog {
  id               String               @id @default(cuid())
  productVariantId String
  productVariant   ProductVariant       @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  fromStatus       ProductVariantStatus?
  toStatus         ProductVariantStatus
  changedById      String
  changedBy        User                 @relation("VariantStatusActor", fields: [changedById], references: [id])
  comment          String?
  changedAt        DateTime             @default(now())

  @@index([productVariantId, changedAt])
}

model OrderStatusLog {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedById String
  changedBy   User         @relation("OrderStatusActor", fields: [changedById], references: [id])
  comment     String?
  changedAt   DateTime     @default(now())

  @@index([orderId, changedAt])
}

// ======================================================
// MONTHLY PLAN
// ======================================================

// План выпуска (не план продаж и не в рублях).
// Алёна: «планирование продуктовое должно идти от количества фасонов и выпущенных
// штук на них предварительно закрепляя ответственных».
//
// Ключ — (yearMonth, ownerId, category). Категория опциональна:
// при null — это «общий план ответственного на месяц».
// plannedRevenue остаётся для исторических данных, но новые планы её не пишут.
// ======================================================
// BRAND PLAN — «Планирование»: направления развития бренда
// ======================================================
// «К весне пиджачная группа: ~5 фасонов по ~55 ¥, тестовая партия N шт,
// бюджет теста не больше X ₽». Задаёт продактам рамку: сколько моделей и
// потолок денег. Факт = привязанные фасоны + стоимость их заказов
// (orderTotalCost, как на /stats) против бюджета. Не удаляем — статус CANCELLED.
model BrandPlan {
  id     String          @id @default(cuid())
  name   String                                        // «Пиджачная группа — весна 2027»
  status BrandPlanStatus @default(IDEA)

  season     String?                                   // как у заказов, строкой
  targetDate DateTime?                                 // к какому сроку запуститься

  plannedModelsCount   Int?                            // сколько фасонов задумано
  plannedUnitsPerModel Int?                            // тестовая партия на фасон, шт
  targetUnitPriceCny   Decimal? @db.Decimal(12, 2)     // примерная закупка за единицу, ¥
  cnyRubRate           Decimal? @db.Decimal(10, 4)
  budgetRub            Decimal? @db.Decimal(14, 2)     // потолок затрат на направление, ₽

  notes   String?
  ownerId String?
  owner   User?   @relation("BrandPlanOwner", fields: [ownerId], references: [id])

  models ProductModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum BrandPlanStatus {
  IDEA        // прикидываем, идём или нет
  APPROVED    // решили: идём
  IN_PROGRESS // продакты работают
  DONE        // запущено
  CANCELLED   // решили не идти (не удаляем)
}

model MonthlyPlan {
  id                String   @id @default(cuid())
  yearMonth         Int
  ownerId           String?
  owner             User?    @relation("PlanOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  category          String?
  plannedModelCount Int?     // План по количеству фасонов
  plannedQuantity   Int?     // План по штукам (выпущенных единиц)
  plannedRevenue    Decimal? @db.Decimal(14, 2) // legacy, не используется в новых планах
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([yearMonth, ownerId, category])
  @@index([yearMonth])
  @@index([ownerId])
  // Плюс ЧАСТИЧНЫЕ уникальные индексы на NULL-комбинации (yearMonth+category при
  // ownerId=NULL, yearMonth+ownerId при category=NULL, yearMonth при обоих NULL)
  // — миграция 20260702200000_monthly_plan_null_unique. Prisma их не отражает в
  // схеме (partial WHERE), но БД ими блокирует дубли «общего плана месяца».
}

// ======================================================
// NOTIFICATION / AUDIT
// ======================================================

model Notification {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotificationChannel
  type       NotificationType
  title      String
  body       String
  entityType String?
  entityId   String?
  sentAt     DateTime?
  readAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

// ======================================================
// PACKAGING (карточки упаковки и их потребность по заказам)
// ======================================================

model PackagingItem {
  id          String        @id @default(cuid())
  name        String                                        // «Бирка с логотипом», «Полибэг 30×40»
  type        PackagingType
  sku         String?                                       // Внутренний код, если есть
  description String?                                       // Подробности (размер, материал)
  photoUrl    String?

  // Стоимость единицы
  unitPriceRub  Decimal?  @db.Decimal(12, 2)
  unitPriceCny  Decimal?  @db.Decimal(12, 2)
  priceCurrency Currency?                                    // RUB | CNY
  cnyRubRate    Decimal?  @db.Decimal(10, 4)

  // Вес штуки, г — для раскидки стоимости карго по весу (Алёна 16.07).
  weightG       Int?

  // Остатки (штуки) — ручной ввод. inProductionQty считается из активных PackagingOrderLine.
  stock            Int @default(0)                          // На складе сейчас
  minStock         Int?                                     // Минимум для предупреждения

  // Жизненный цикл (как у фасона)
  status              PackagingItemStatus @default(ACTIVE)
  ownerId             String?
  owner               User?               @relation("PackagingOwner", fields: [ownerId], references: [id])
  decisionDate        DateTime?                             // Решение делать
  designReadyDate     DateTime?                             // Макет готов
  sampleRequestedDate DateTime?                             // Образец заказан
  sampleApprovedDate  DateTime?                             // Образец утверждён
  productionStartDate DateTime?                             // Запущено в массовое производство

  notes    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderUsages         OrderPackaging[]
  modelUsages         ModelPackaging[]
  payments            Payment[]
  statusLogs          PackagingItemStatusLog[]
  packagingOrderLines PackagingOrderLine[]

  @@index([type])
  @@index([isActive])
  @@index([status])
  @@index([ownerId])
}

model PackagingItemStatusLog {
  id               String              @id @default(cuid())
  packagingItemId  String
  packagingItem    PackagingItem       @relation(fields: [packagingItemId], references: [id], onDelete: Cascade)
  fromStatus       PackagingItemStatus?
  toStatus         PackagingItemStatus
  comment          String?
  changedById      String
  changedBy        User                @relation("PackagingStatusActor", fields: [changedById], references: [id])
  changedAt        DateTime            @default(now())

  @@index([packagingItemId, changedAt])
}

model OrderPackaging {
  id               String        @id @default(cuid())
  orderId          String
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  packagingItemId  String
  packagingItem    PackagingItem @relation(fields: [packagingItemId], references: [id])

  quantityPerUnit  Decimal @default(1) @db.Decimal(6, 2)    // Сколько штук упаковки на 1 ед. товара
  notes            String?

  // Строка пришла из комплекта фасона (авто-синк). Такие строки зеркалятся с
  // фасоном: смена комплекта в карточке фасона обновляет/убирает их в открытых
  // заказах. Ручные правки в заказе снимают флаг — их синк не трогает.
  syncedFromModel  Boolean @default(false)

  // Сколько штук упаковки СПИСАНО со склада при переходе заказа в «Упаковка».
  // null — ещё не списывали. Нужно, чтобы: (1) не списать дважды при повторном
  // входе в PACKING; (2) корректно вернуть остаток при откате статуса назад.
  consumedQty      Int?

  createdAt DateTime @default(now())

  @@unique([orderId, packagingItemId])
  @@index([orderId])
  @@index([packagingItemId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ======================================================
// PAYMENT — Платёжный календарь
// ======================================================
// Один платёж = одна строка в календаре. Для заказа может быть 1..N платежей
// (30/70 → 2, 50/30/20 → 3, 100% → 1). Для упаковки — произвольно вручную.

model Payment {
  id          String        @id @default(cuid())
  type        PaymentType
  status      PaymentStatus @default(PENDING)

  plannedDate DateTime      // Плановая дата оплаты
  paidAt      DateTime?     // Фактическая дата оплаты (ставится при отметке PAID)

  amount      Decimal       @db.Decimal(14, 2)
  currency    Currency      @default(RUB)

  label       String        // «Предоплата 30%», «Постоплата», «Бирки апрель»
  invoiceUrl  String?
  notes       String?

  // Связи для type = ORDER
  orderId     String?
  order       Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  factoryId   String?       // дубль для быстрого фильтра
  factory     Factory?      @relation(fields: [factoryId], references: [id], onDelete: SetNull)

  // Связи для type = PACKAGING
  packagingItemId  String?
  packagingItem    PackagingItem?  @relation(fields: [packagingItemId], references: [id], onDelete: SetNull)
  supplierName     String?         // Свободный текст — поставщик упаковки
  packagingOrderId String?
  packagingOrder   PackagingOrder? @relation(fields: [packagingOrderId], references: [id], onDelete: SetNull)

  // Кто создал / кто оплатил
  createdById String
  createdBy   User     @relation("PaymentCreator", fields: [createdById], references: [id])
  paidById    String?
  paidBy      User?    @relation("PaymentPayer", fields: [paidById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Фактические разнесения оплат фабрикам на этот плановый платёж.
  allocations PayoutAllocation[]

  @@index([type])
  @@index([status])
  @@index([plannedDate])
  @@index([orderId])
  @@index([factoryId])
  @@index([packagingItemId])
  @@index([packagingOrderId])
}

// ======================================================
// ОПЛАТЫ ФАБРИКАМ — фактические переводы денег с разнесением по плановым платежам
// ======================================================
//
// Боль владельца: «оплату зафиксировали, а потом фиг знает как списать; 5 заказов
// с одной фабрики, а списывается скопом». Payment — это ПЛАН (график по заказу).
// FactoryPayout — ФАКТ перевода: одной суммой закрываем сразу несколько плановых
// платежей через PayoutAllocation.
model FactoryPayout {
  id           String    @id @default(cuid())
  date         DateTime                          // Дата фактического перевода
  amount       Decimal   @db.Decimal(14, 2)      // Сумма перевода в ₽
  currencyNote String?                           // Справочно, если платили в валюте: «≈36 500 ¥»
  comment      String?

  factoryId    String
  factory      Factory   @relation(fields: [factoryId], references: [id])

  createdById  String
  createdBy    User      @relation("PayoutCreator", fields: [createdById], references: [id])

  createdAt    DateTime  @default(now())
  deletedAt    DateTime?                         // Мягкое удаление — «никогда не удалять»

  allocations  PayoutAllocation[]

  @@index([factoryId])
  @@index([date])
  @@index([deletedAt])
}

// Разнесение одной оплаты на один плановый платёж. Сумма оплаты = сумма её allocations
// (плюс возможный нераспределённый остаток).
model PayoutAllocation {
  id        String        @id @default(cuid())
  payoutId  String
  payout    FactoryPayout @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  paymentId String
  payment   Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(14, 2)

  createdAt DateTime @default(now())

  @@unique([payoutId, paymentId])
  @@index([paymentId])
  @@index([payoutId])
}

// ======================================================
// PACKAGING ORDER — заказы поставщику на упаковку
// ======================================================
model PackagingOrder {
  id              String        @id @default(cuid())
  orderNumber     String        @unique                       // PKG-2026-0001

  factoryId       String?
  factory         Factory?      @relation("PackagingOrderFactory", fields: [factoryId], references: [id])
  supplierName    String?

  status          PackagingOrderStatus @default(ORDERED)

  // decisionDate — старт «Разработки» заказа упаковки (когда решили делать).
  // Если null, в графике Ганта берётся как orderedDate (фаза Разработка
  // нулевой длительности).
  decisionDate        DateTime?
  orderedDate         DateTime      @default(now())
  productionEndDate   DateTime?
  expectedDate        DateTime?
  arrivedDate         DateTime?

  deliveryMethod  DeliveryMethod?

  // Каким карго едет (лист КАРГО: упаковка едет теми же накладными, что одежда).
  shipmentId      String?
  shipment        Shipment?     @relation(fields: [shipmentId], references: [id])
  // Вес заказа упаковки в карго, кг — ручная поправка (null = штуки × вес штуки).
  weightKgOverride Decimal?     @db.Decimal(10, 1)

  ownerId         String
  owner           User          @relation("PackagingOrderOwner", fields: [ownerId], references: [id])

  notes           String?
  payments        Payment[]
  lines           PackagingOrderLine[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([factoryId])
  @@index([shipmentId])
}

model PackagingOrderLine {
  id               String         @id @default(cuid())
  packagingOrderId String
  packagingOrder   PackagingOrder @relation(fields: [packagingOrderId], references: [id], onDelete: Cascade)
  packagingItemId  String
  packagingItem    PackagingItem  @relation(fields: [packagingItemId], references: [id])

  quantity         Int
  unitPriceRub     Decimal?       @db.Decimal(12, 2)
  unitPriceCny     Decimal?       @db.Decimal(12, 2)
  priceCurrency    Currency?
  cnyRubRate       Decimal?       @db.Decimal(10, 4)

  createdAt        DateTime @default(now())

  @@index([packagingOrderId])
  @@index([packagingItemId])
}

enum PackagingOrderStatus {
  ORDERED
  IN_PRODUCTION
  IN_TRANSIT
  ARRIVED
  CANCELLED
}

// ======================================================
// COMMENT — универсальные комментарии (полиморфно)
// ======================================================

model Comment {
  id          String   @id @default(cuid())

  // Полиморфная привязка: "model" | "order" (потенциально другие сущности).
  // Не делаем явных foreign key — для гибкости. Целостность через приложение.
  entityType  String
  entityId    String

  authorId    String
  body        String   @db.Text
  photoUrls   String[] @default([])

  // Зарезервировано под треды — пока не используется в UI.
  parentId    String?

  createdAt   DateTime  @default(now())
  // Null если не правили. При редактировании — обновляется.
  updatedAt   DateTime?
  // Soft delete — никогда не удаляем физически.
  deletedAt   DateTime?

  @@index([entityType, entityId, createdAt])
  @@index([authorId])
}

// ======================================================
// BOARD ITEM — свободные элементы доски фасонов (/models/board)
// ======================================================
// Помимо карточек фасонов на доску можно класть свободные элементы как в Miro:
// текстовые блоки (размер/жирность/цвет), цветные стикеры и отдельные картинки
// (не привязанные к фасону). Доска общая на команду.

enum BoardItemType {
  TEXT
  STICKY
  IMAGE
}

model BoardItem {
  id   String        @id @default(cuid())
  type BoardItemType

  // Геометрия в мировых координатах доски
  x        Float
  y        Float
  w        Float
  h        Float
  z        Int    @default(0)
  rotation Float  @default(0)

  // Контент
  text       String? @db.Text
  color      String?
  fontSize   Int?
  fontWeight Int?
  align      String?
  fontFamily String? // ключ рукописного шрифта для курсивных надписей (null = обычный)
  imageUrl   String?

  createdById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@index([z])
}
