// White One ERP v2 — Prisma schema
// Фокус: продуктовая разработка. WB-метрики вне системы.
// Ядра: ProductModel (фасон) + ProductVariant (цветовой вариант) + Order.
// Дополнительно: Sample (образец), Idea (идея), SizeGrid (размерные сетки).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================================
// ENUMS
// ======================================================

enum Role {
  OWNER
  DIRECTOR
  PRODUCT_MANAGER
  ASSISTANT
  CONTENT_MANAGER
  LOGISTICS
  CUSTOMS
  WB_MANAGER
  INTERN
}

enum DevelopmentType {
  OWN
  REPEAT
}

// Упрощённая машина статусов (5 вместо 8).
// Корректировки и размерная сетка — подэтапы SAMPLE через чекбоксы.
enum ProductModelStatus {
  IDEA
  PATTERNS
  SAMPLE
  APPROVED
  IN_PRODUCTION
}

enum ProductVariantStatus {
  DRAFT
  READY_TO_ORDER
  DISCONTINUED
}

enum OrderType {
  SEASONAL
  RESTOCK
  TEST
}

enum OrderStatus {
  PREPARATION
  FABRIC_ORDERED
  SEWING
  QC
  READY_SHIP
  IN_TRANSIT
  WAREHOUSE_MSK
  PACKING
  SHIPPED_WB
  ON_SALE
}

enum DeliveryMethod {
  CARGO
  AIR
  RAIL
  DOMESTIC
}

enum SampleStatus {
  REQUESTED       // Заказан на фабрике
  IN_SEWING       // В пошиве
  DELIVERED       // Доставлен в Москву
  APPROVED        // Утверждён
  READY_FOR_SHOOT // Готов для фотосессии
  RETURNED        // Возвращён / утилизирован
}

enum IdeaStatus {
  NEW
  CONSIDERING
  PROMOTED
  REJECTED
}

enum IdeaPriority {
  HIGH
  MEDIUM
  LOW
}

enum QcDefectCategory {
  SEWING    // Пошив
  FABRIC    // Ткань
  FITTINGS  // Фурнитура
  SIZE      // Размер
  OTHER
}

enum NotificationChannel {
  TELEGRAM
  IN_APP
  EMAIL
}

enum NotificationType {
  DELAY
  INCOMING_DELIVERY
  PAYMENT_DUE
  PLAN_GAP
  STATUS_CHANGED
  ISSUE
  SAMPLE_READY
  QC_REQUIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  IMPORT
  EXPORT
}

enum Currency {
  RUB
  CNY
}

// ======================================================
// USER
// ======================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(INTERN)
  isActive     Boolean  @default(true)

  telegramChatId   BigInt?   @unique
  telegramLinkCode String?
  telegramLinkedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedModels       ProductModel[]       @relation("ModelOwner")
  ownedOrders       Order[]              @relation("OrderOwner")
  modelLogs         ProductModelStatusLog[] @relation("ModelStatusActor")
  variantLogs       ProductVariantStatusLog[] @relation("VariantStatusActor")
  orderLogs         OrderStatusLog[]     @relation("OrderStatusActor")
  sampleLogs        SampleStatusLog[]    @relation("SampleStatusActor")
  approvedSamples   Sample[]             @relation("SampleApprover")
  ideasCreated      Idea[]               @relation("IdeaCreator")
  auditLogs         AuditLog[]
  notifications     Notification[]

  @@index([role])
  @@index([isActive])
}

// ======================================================
// FACTORY
// ======================================================

model Factory {
  id               String   @id @default(cuid())
  name             String   @unique
  country          String
  city             String?
  contactName      String?
  contactInfo      String?
  capacityPerMonth Int?
  notes            String?
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferredForModels ProductModel[] @relation("ModelPreferredFactory")
  orders             Order[]

  @@index([isActive])
}

// ======================================================
// SIZE GRID (справочник размерных сеток)
// ======================================================

model SizeGrid {
  id        String   @id @default(cuid())
  name      String   @unique                 // "40-60 пальто", "42-52 стандарт", "XS-XXL"
  sizes     String[]                         // ["40", "42", "44", "46", "48", "50"]
  notes     String?

  createdAt DateTime @default(now())

  models ProductModel[]
}

// ======================================================
// PRODUCT MODEL (фасон)
// ======================================================

model ProductModel {
  id           String          @id @default(cuid())
  name         String                                           // "Пальто Классика Двубортное Миди"
  category     String                                           // Пальто / Брюки / Лето / Новые товары
  subcategory  String?                                          // Пальто Классика Миди / Палаццо оверсайз / ...

  // Теги вместо коллекций — свободный массив, автоподсказка из существующих
  tags         String[]                                         // ["Осень 2026", "Офис"]

  // Размерная сетка
  sizeGridId   String?
  sizeGrid     SizeGrid?       @relation(fields: [sizeGridId], references: [id])

  // Ткань — простые опциональные поля (не отдельная сущность)
  fabricName           String?
  fabricConsumption    Decimal? @db.Decimal(6, 2)               // метров на единицу
  fabricPricePerMeter  Decimal? @db.Decimal(12, 2)
  fabricCurrency       Currency?                                // RUB | CNY

  // Производство
  countryOfOrigin      String                                   // "Россия" / "Китай" / "Кыргызстан"
  preferredFactoryId   String?
  preferredFactory     Factory? @relation("ModelPreferredFactory", fields: [preferredFactoryId], references: [id])

  developmentType DevelopmentType @default(OWN)
  isRepeat         Boolean         @default(false)
  previousVersionId String?                                     // Ссылка на предыдущую версию (self-ref)
  previousVersion   ProductModel?  @relation("ModelVersioning", fields: [previousVersionId], references: [id])
  nextVersions      ProductModel[] @relation("ModelVersioning")

  // Документация — именованные слоты
  patternsUrl       String?
  patternVersion    String?                                     // v1 / v2 / v3
  techPackUrl       String?
  sampleApprovalUrl String?                                     // фото финально утверждённого образца

  // Фото модели (общие, без цвета). Обязательно минимум 1 после SAMPLE.
  photoUrls         String[]

  // Подэтапы SAMPLE (флаги, не статусы)
  correctionsNeeded Boolean @default(false)
  sizeChartReady    Boolean @default(false)

  status     ProductModelStatus @default(IDEA)
  ownerId    String
  owner      User           @relation("ModelOwner", fields: [ownerId], references: [id])

  // Даты этапов
  patternsDate DateTime?
  sampleDate   DateTime?
  approvedDate DateTime?
  productionStartDate DateTime?
  plannedLaunchMonth Int?                                       // YYYYMM

  notes     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  variants    ProductVariant[]
  samples     Sample[]
  statusLogs  ProductModelStatusLog[]
  promotedFromIdea Idea?                                       @relation("IdeaPromoted")

  @@index([status])
  @@index([ownerId])
  @@index([category])
  @@index([deletedAt])
  @@index([plannedLaunchMonth])
}

// ======================================================
// PRODUCT VARIANT (цветовой вариант)
// ======================================================

model ProductVariant {
  id             String  @id @default(cuid())
  productModelId String
  productModel   ProductModel @relation(fields: [productModelId], references: [id])

  sku            String  @unique                // П_038_шоколад_безэполет
  colorName      String                          // шоколад
  pantoneCode    String?                         // 18-1418 TCX

  // Фото — КРИТИЧНО. Минимум 1 фото валидируется на уровне формы.
  photoUrls      String[]

  // Размерная пропорция по умолчанию { "42": 10, "44": 25, ... } (%)
  defaultSizeProportion Json?

  // Финансы (вводимые)
  purchasePriceCny     Decimal? @db.Decimal(12, 2)
  purchasePriceRub     Decimal? @db.Decimal(12, 2)
  cnyRubRate           Decimal? @db.Decimal(10, 4)
  packagingCost        Decimal  @default(0) @db.Decimal(12, 2)
  wbLogisticsCost      Decimal  @default(0) @db.Decimal(12, 2)
  wbPrice              Decimal? @db.Decimal(12, 2)
  customerPrice        Decimal? @db.Decimal(12, 2)
  wbCommissionPct      Decimal  @default(0) @db.Decimal(5, 2)
  drrPct               Decimal  @default(0) @db.Decimal(5, 2)
  plannedRedemptionPct Decimal? @db.Decimal(5, 2)

  // Финансы (расчётные)
  fullCost             Decimal? @db.Decimal(12, 2)
  marginBeforeDrr      Decimal? @db.Decimal(12, 2)
  marginAfterDrrPct    Decimal? @db.Decimal(6, 2)
  roi                  Decimal? @db.Decimal(6, 2)
  markupPct            Decimal? @db.Decimal(6, 2)

  // Габариты (могут переопределяться на уровне варианта)
  lengthCm Decimal? @db.Decimal(6, 1)
  widthCm  Decimal? @db.Decimal(6, 1)
  heightCm Decimal? @db.Decimal(6, 1)
  weightG  Int?
  liters   Decimal? @db.Decimal(6, 2)

  hsCode   String?                               // ТНВЭД (может различаться по цвету)
  packagingType String?

  status ProductVariantStatus @default(DRAFT)

  notes    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  orders     Order[]
  samples    Sample[]
  statusLogs ProductVariantStatusLog[]

  @@index([productModelId])
  @@index([sku])
  @@index([status])
  @@index([deletedAt])
}

// ======================================================
// SAMPLE (образец — отдельный pipeline)
// ======================================================

model Sample {
  id               String       @id @default(cuid())
  productModelId   String
  productModel     ProductModel @relation(fields: [productModelId], references: [id])
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  status SampleStatus @default(REQUESTED)

  requestDate       DateTime @default(now())
  sewingStartDate   DateTime?
  deliveredDate     DateTime?
  approvedDate      DateTime?
  readyForShootDate DateTime?
  returnedDate      DateTime?

  // Утверждение
  approvedById      String?
  approvedBy        User?    @relation("SampleApprover", fields: [approvedById], references: [id])
  approvalComment   String?
  approvedPhotoUrl  String?

  // Контент-отдел: когда планируется съёмка
  plannedShootDate  DateTime?
  shootCompleted    Boolean  @default(false)

  photoUrls         String[]
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusLogs SampleStatusLog[]

  @@index([productModelId])
  @@index([productVariantId])
  @@index([status])
}

// ======================================================
// ORDER (заказы на производство)
// ======================================================

model Order {
  id               String          @id @default(cuid())
  orderNumber      String          @unique
  productVariantId String
  productVariant   ProductVariant  @relation(fields: [productVariantId], references: [id])

  orderType   OrderType
  season      String?
  launchMonth Int

  quantity    Int

  // Размерная матрица — план и факт
  sizeDistribution       Json?                                  // { "42": 50, "44": 120, ... }
  sizeDistributionActual Json?                                  // По факту приёмки

  // Снимки финансов (копируются из variant в момент создания)
  snapshotFullCost         Decimal? @db.Decimal(12, 2)
  snapshotWbPrice          Decimal? @db.Decimal(12, 2)
  snapshotCustomerPrice    Decimal? @db.Decimal(12, 2)
  snapshotWbCommissionPct  Decimal? @db.Decimal(5, 2)
  snapshotDrrPct           Decimal? @db.Decimal(5, 2)
  snapshotRedemptionPct    Decimal? @db.Decimal(5, 2)

  // Расчётные
  batchCost      Decimal? @db.Decimal(14, 2)
  plannedRevenue Decimal? @db.Decimal(14, 2)
  plannedMargin  Decimal? @db.Decimal(14, 2)

  // Производство
  factoryId      String?
  factory        Factory? @relation(fields: [factoryId], references: [id])
  ownerId        String
  owner          User     @relation("OrderOwner", fields: [ownerId], references: [id])
  deliveryMethod DeliveryMethod?

  status OrderStatus @default(PREPARATION)

  // Даты этапов
  decisionDate         DateTime?
  handedToFactoryDate  DateTime?
  sewingStartDate      DateTime?
  readyAtFactoryDate   DateTime?
  shipmentDate         DateTime?
  arrivalPlannedDate   DateTime?
  arrivalActualDate    DateTime?
  packingDoneDate      DateTime?
  wbShipmentDate       DateTime?
  saleStartDate        DateTime?

  // Оплаты
  paymentTerms       String?
  prepaymentAmount   Decimal?  @db.Decimal(14, 2)
  prepaymentDate     DateTime?
  prepaymentPaid     Boolean   @default(false)
  finalPaymentAmount Decimal?  @db.Decimal(14, 2)
  finalPaymentDate   DateTime?
  finalPaymentPaid   Boolean   @default(false)

  // Упаковка
  packagingType    String?
  packagingOrdered Boolean @default(false)

  // ВЭД
  specReady        Boolean @default(false)
  specUrl          String?
  declarationReady Boolean @default(false)
  declarationUrl   String?

  // QC — секция на заказе, не отдельный модуль
  qcDate              DateTime?
  qcQuantityOk        Int?
  qcQuantityDefects   Int?
  qcDefectsPhotoUrl   String?
  qcDefectCategory    QcDefectCategory?
  qcReplacedByFactory Boolean  @default(false)
  qcResolutionNote    String?

  // Флаги
  isDelayed   Boolean @default(false)
  hasIssue    Boolean @default(false)
  wbCardReady Boolean @default(false)

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  statusLogs OrderStatusLog[]

  @@index([orderNumber])
  @@index([productVariantId])
  @@index([status])
  @@index([launchMonth])
  @@index([ownerId])
  @@index([factoryId])
  @@index([deletedAt])
  @@index([isDelayed])
}

// ======================================================
// STATUS LOGS
// ======================================================

model ProductModelStatusLog {
  id             String              @id @default(cuid())
  productModelId String
  productModel   ProductModel        @relation(fields: [productModelId], references: [id], onDelete: Cascade)
  fromStatus     ProductModelStatus?
  toStatus       ProductModelStatus
  changedById    String
  changedBy      User                @relation("ModelStatusActor", fields: [changedById], references: [id])
  comment        String?
  changedAt      DateTime            @default(now())

  @@index([productModelId, changedAt])
}

model ProductVariantStatusLog {
  id               String               @id @default(cuid())
  productVariantId String
  productVariant   ProductVariant       @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  fromStatus       ProductVariantStatus?
  toStatus         ProductVariantStatus
  changedById      String
  changedBy        User                 @relation("VariantStatusActor", fields: [changedById], references: [id])
  comment          String?
  changedAt        DateTime             @default(now())

  @@index([productVariantId, changedAt])
}

model OrderStatusLog {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedById String
  changedBy   User         @relation("OrderStatusActor", fields: [changedById], references: [id])
  comment     String?
  changedAt   DateTime     @default(now())

  @@index([orderId, changedAt])
}

model SampleStatusLog {
  id          String        @id @default(cuid())
  sampleId    String
  sample      Sample        @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  fromStatus  SampleStatus?
  toStatus    SampleStatus
  changedById String
  changedBy   User          @relation("SampleStatusActor", fields: [changedById], references: [id])
  comment     String?
  changedAt   DateTime      @default(now())

  @@index([sampleId, changedAt])
}

// ======================================================
// MONTHLY PLAN
// ======================================================

model MonthlyPlan {
  id              String  @id @default(cuid())
  yearMonth       Int
  category        String
  plannedRevenue  Decimal @db.Decimal(14, 2)
  plannedQuantity Int?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([yearMonth, category])
  @@index([yearMonth])
}

// ======================================================
// IDEA (пул идей)
// ======================================================

model Idea {
  id          String       @id @default(cuid())
  title       String
  description String?
  tags        String[]
  priority    IdeaPriority @default(MEDIUM)
  status      IdeaStatus   @default(NEW)

  createdById String
  createdBy   User         @relation("IdeaCreator", fields: [createdById], references: [id])

  rejectedReason   String?
  promotedToModelId String?       @unique
  promotedToModel   ProductModel? @relation("IdeaPromoted", fields: [promotedToModelId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([createdById])
}

// ======================================================
// NOTIFICATION / AUDIT
// ======================================================

model Notification {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotificationChannel
  type       NotificationType
  title      String
  body       String
  entityType String?
  entityId   String?
  sentAt     DateTime?
  readAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
}
